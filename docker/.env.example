# ==========================================
# AIGC GEO Overseas Platform - Environment Configuration
# ==========================================
# Copy this file to .env and fill in actual values:
#   cp docker/.env.example .env
# ==========================================

# ---------- Application Configuration ----------
APP_NAME=AIGC GEO Overseas Platform
APP_VERSION=1.0.0
DEBUG=false

# ---------- PostgreSQL Database ----------
# Docker Compose internally uses service name postgres as host
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=aigc_geo_overseas
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ---------- JWT Secret ----------
# For production, use a strong random key: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------- CORS ----------
CORS_ORIGINS=["*"]

# ==========================================
# OpenRouter API Configuration (Unified AIGC Gateway)
# Get your API key from: https://openrouter.ai/keys
# ==========================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://www.TopcentralGEO.com
OPENROUTER_MODELS=["openai/gpt-4o","anthropic/claude-sonnet-4","x-ai/grok-3","google/gemini-2.0-flash","perplexity/sonar","deepseek/deepseek-chat"]

# ==========================================
# Nginx / Domain Configuration
# ==========================================
NGINX_HOST=localhost
NGINX_PORT=80
NGINX_SSL_PORT=443

# ==========================================
# Deployment Mode
# ==========================================
# Values: dev / prod
DEPLOY_ENV=prod
